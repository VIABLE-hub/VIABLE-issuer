# StudentVC Production Deployment Configuration
# ============================================
# Copy this file to .env before deployment and modify the values

# Multi-Tenant Configuration
# ---------------------------
# TU Berlin (TUB) Tenant - Update with your actual ngrok URLs
TUB_NGROK_URL=https://tub-studentvc.ngrok.io
TUB_PORT=8080

# Freie Universität Berlin (FUB) Tenant - Update with your actual ngrok URLs
FUB_NGROK_URL=https://fub-studentvc.ngrok.io
FUB_PORT=8081

# Root/Default Tenant - Update with your actual ngrok URLs  
ROOT_NGROK_URL=https://root-studentvc.ngrok.io
ROOT_PORT=8082

# Global Application Settings
# ---------------------------
FLASK_ENV=production
USE_HTTPS=true
SERVER_HOST=0.0.0.0

# Security Configuration - CHANGE THESE IN PRODUCTION!
# ----------------------------------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production-use-64-chars
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production-use-64-chars

# Database Configuration
# ----------------------
DATABASE_PATH=/app/data
STATIC_PATH=/app/static

# Container Configuration
# -----------------------
PYTHONPATH=/app

# SSL Configuration (if using custom certificates)
# ------------------------------------------------
SSL_CERT_PATH=/etc/ssl/certs/studentvc.crt
SSL_KEY_PATH=/etc/ssl/private/studentvc.key

# NGINX Configuration
# -------------------
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# Redis Configuration (for session storage)
# -----------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=100

# Monitoring & Logging
# --------------------
LOG_LEVEL=INFO
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# Resource Limits
# ---------------
MEMORY_LIMIT=512Mi
CPU_LIMIT=500m
MEMORY_REQUEST=256Mi
CPU_REQUEST=100m

# Backup Configuration
# -------------------
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Development Settings (set to false for production)
# --------------------------------------------------
DEBUG=false
DEVELOPMENT_MODE=false 