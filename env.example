# StudentVC Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files to version control

# ===========================================
# FLASK APPLICATION SETTINGS
# ===========================================

# Flask environment (development, production, testing)
FLASK_ENV=development

# Secret key for Flask sessions and CSRF protection
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here

# Debug mode (True for development, False for production)
FLASK_DEBUG=True

# Flask app module
FLASK_APP=backend/main.py

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# HTTPS configuration
USE_HTTPS=True
SSL_CERT_PATH=adhoc
SSL_KEY_PATH=adhoc

# External server URL for QR codes and mobile wallet integration
# This should be your ngrok URL or public domain
SERVER_URL=https://localhost:8080

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Database URL (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///backend/instance/studentvc.db

# Database connection pool settings (for production)
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ===========================================
# CRYPTOGRAPHIC SETTINGS
# ===========================================

# BBS+ Core library settings
BBS_CORE_PATH=backend/bbs_core

# Key storage directory
KEY_STORAGE_PATH=backend/instance/keys

# Credential signing key (generated automatically if not set)
ISSUER_PRIVATE_KEY_PATH=backend/instance/keys/issuer_private_key.json

# Verification key paths
VERIFICATION_KEY_PATH=backend/instance/keys/verification_key.json

# ===========================================
# NGROK CONFIGURATION
# ===========================================

# NGROK settings for external access during development
NGROK_ENABLED=True
NGROK_URL=https://your-ngrok-url.ngrok.io

# NGROK authentication (if using paid plan)
NGROK_AUTH_TOKEN=your-ngrok-auth-token

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=backend/logs/studentvc.log

# Maximum log file size (in bytes)
LOG_MAX_SIZE=10485760

# Number of log file backups to keep
LOG_BACKUP_COUNT=5

# ===========================================
# UNIVERSITY/TENANT CONFIGURATION
# ===========================================

# Default university/tenant settings
DEFAULT_UNIVERSITY_NAME=TU Berlin
DEFAULT_UNIVERSITY_DOMAIN=tu-berlin.de
DEFAULT_UNIVERSITY_LOGO=studentVC-logo-sora-cropped-darkmode.png

# Multi-tenant support
MULTI_TENANT_ENABLED=False

# ===========================================
# CREDENTIAL SETTINGS
# ===========================================

# Default credential template
DEFAULT_CREDENTIAL_TEMPLATE=student_id

# Credential validity period (in days)
CREDENTIAL_VALIDITY_DAYS=365

# Supported credential types
SUPPORTED_CREDENTIAL_TYPES=student_id,diploma,certificate

# ===========================================
# SELECTIVE DISCLOSURE CONFIGURATION
# ===========================================

# Default fields for selective disclosure
DEFAULT_SELECTIVE_FIELDS=firstName,lastName,studentId,program,issueDate

# Mandatory fields (always included)
MANDATORY_FIELDS=iss,sub,type,issuanceDate

# Optional fields (can be selectively disclosed)
OPTIONAL_FIELDS=firstName,lastName,studentId,program,email,dateOfBirth

# ===========================================
# SECURITY SETTINGS
# ===========================================

# Session timeout (in minutes)
SESSION_TIMEOUT=60

# Maximum file upload size (in bytes)
MAX_UPLOAD_SIZE=5242880

# Allowed file extensions for uploads
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif

# Cross-Origin Resource Sharing (CORS) settings
CORS_ENABLED=True
CORS_ORIGINS=https://localhost:8080,https://*.ngrok.io

# Content Security Policy
CSP_ENABLED=True

# ===========================================
# MOBILE WALLET INTEGRATION
# ===========================================

# QR code settings
QR_CODE_SIZE=256
QR_CODE_ERROR_CORRECTION=M

# Mobile wallet callback URLs
WALLET_CALLBACK_SUCCESS=/callback/success
WALLET_CALLBACK_ERROR=/callback/error

# Deep link scheme for mobile apps
MOBILE_APP_SCHEME=studentwallet

# ===========================================
# TESTING CONFIGURATION
# ===========================================

# Test database URL
TEST_DATABASE_URL=sqlite:///backend/instance/test_studentvc.db

# Test mode settings
TEST_MODE=False
SKIP_BBS_CRYPTO=False

# Mock external services during testing
MOCK_NGROK=False

# ===========================================
# PERFORMANCE SETTINGS
# ===========================================

# Caching configuration
CACHE_ENABLED=True
CACHE_TYPE=simple
CACHE_TIMEOUT=300

# Rate limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_DEFAULT=100 per hour

# ===========================================
# MONITORING AND ANALYTICS
# ===========================================

# Health check endpoint
HEALTH_CHECK_ENABLED=True

# Metrics collection
METRICS_ENABLED=False

# External monitoring service URLs
HEALTH_CHECK_URL=/health
METRICS_ENDPOINT=/metrics

# ===========================================
# DEVELOPMENT TOOLS
# ===========================================

# Hot reloading for development
AUTO_RELOAD=True

# Profiling and debugging
PROFILE_ENABLED=False
DEBUG_TOOLBAR_ENABLED=False

# Static file serving
SERVE_STATIC_FILES=True

# ===========================================
# BACKUP AND RECOVERY
# ===========================================

# Automatic backup settings
AUTO_BACKUP_ENABLED=False
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_DIRECTORY=backend/backups

# ===========================================
# THIRD-PARTY INTEGRATIONS
# ===========================================

# Email configuration (for notifications)
EMAIL_ENABLED=False
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# External API keys
EXTERNAL_API_KEY=your-api-key-here

# ===========================================
# PRODUCTION-SPECIFIC SETTINGS
# ===========================================

# Production database configuration
PRODUCTION_DB_URL=postgresql://user:password@localhost/studentvc_prod

# Production security settings
PRODUCTION_SECRET_KEY=your-production-secret-key
SECURE_COOKIES=True
HTTPS_REDIRECT=True

# Load balancer and proxy settings
PROXY_FIX_ENABLED=False
TRUSTED_PROXIES=127.0.0.1

# ===========================================
# DEPLOYMENT CONFIGURATION
# ===========================================

# Docker settings
DOCKER_ENABLED=False
CONTAINER_PORT=8080

# Kubernetes settings
K8S_NAMESPACE=default
K8S_SERVICE_NAME=studentvc

# Cloud provider settings
CLOUD_PROVIDER=none
CLOUD_REGION=us-east-1

# Basic Settings
SECRET_KEY=your-secret-key-here
DEBUG=False

# Tenant Configuration
TENANT_ID=root

# NGROK Configuration (optional)
NGROK_URL=

# Simple Authentication (NEW)
# Enable password protection for the entire platform
ENABLE_AUTH=False
ACCESS_PASSWORD=studentvc2024

# Email 2FA (optional - only if you want email verification)
REQUIRE_EMAIL_2FA=False
ADMIN_EMAIL=your-email@example.com
SMTP_EMAIL=your-smtp-email@gmail.com
SMTP_PASSWORD=your-app-password 